    { "name": "confidence", "type": "INTEGER", "required": false },
    { "name": "last_seen", "type": "DATE", "required": false },
    { "name": "completion_status", "type": "ENUM", "required": true, "default": "not_started", "options": ["not_started", "in_progress", "complete"] },
    { "name": "prerequisite_met", "type": "BOOLEAN", "required": true, "default": false }
  ],
  "config": {}
}