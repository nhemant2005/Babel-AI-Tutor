{
  "name": "note-banker-agent",
  "description": "Post-session agent: writes session notes, updates student profile, assesses recall quality, updates learner model.",
  "instruction": { "$file": "instruction.md" },
  "toolsets": ["POD"],
  "visibility": "POD",
  "permissions": { "grants": [
    { "resource_type": "datastore_table", "resource_name": "learner_model",
      "permission_ids": ["datastore.table.read", "datastore.record.write"] },
    { "resource_type": "datastore_table", "resource_name": "sessions",
      "permission_ids": ["datastore.table.read", "datastore.record.write"] },
    { "resource_type": "datastore_table", "resource_name": "notifications",
      "permission_ids": ["datastore.table.read", "datastore.record.write"] },
    { "resource_type": "file_path", "resource_name": "/student/",
      "permission_ids": ["file.read", "file.write"] },
    { "resource_type": "file_path", "resource_name": "/subjects/",
      "permission_ids": ["file.read", "file.write"] }
  ] }
}
