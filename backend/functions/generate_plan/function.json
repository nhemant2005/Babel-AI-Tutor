{
  "name": "generate-plan",
  "description": "Deterministic scheduler: reads subject topics ranked by depth_rank, distributes across available_days within deadline, writes to plan table.",
  "type": "API",
  "visibility": "POD",
  "code": { "$file": "code.py" },
  "permissions": { "grants": [
    { "resource_type": "datastore_table", "resource_name": "subjects",
      "permission_ids": ["datastore.table.read", "datastore.record.read"] },
    { "resource_type": "datastore_table", "resource_name": "topics",
      "permission_ids": ["datastore.table.read", "datastore.record.read"] },
    { "resource_type": "datastore_table", "resource_name": "plan",
      "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] },
    { "resource_type": "datastore_table", "resource_name": "notifications",
      "permission_ids": ["datastore.table.read", "datastore.record.write"] }
  ] }
}
