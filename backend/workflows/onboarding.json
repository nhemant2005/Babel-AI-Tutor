{
  "name": "onboarding",
  "description": "Triggered when user completes material upload and intake questions. Runs structural pass, caches result, generates plan, marks subject active.",
  "start": { "type": "MANUAL" },
  "visibility": "POD",
  "nodes": [
    {
      "id": "intake",
      "type": "FORM",
      "label": "Intake",
      "config": {
        "input_schema": {
          "type": "object",
          "properties": {
            "subject_id": { "type": "string" },
            "material_content": { "type": "string" },
            "material_hash": { "type": "string" }
          },
          "required": ["subject_id", "material_content", "material_hash"]
        }
      }
    },
    {
      "id": "cache_check",
      "type": "FUNCTION",
      "label": "Check Cache",
      "config": {
        "function_name": "cache-lookup",
        "input_mapping": {
          "cache_key": { "type": "expression", "value": "intake.material_hash" },
          "cache_type": { "type": "literal", "value": "structural" }
        }
      }
    },
    {
      "id": "cache_hit_decision",
      "type": "DECISION",
      "label": "Cache Hit?",
      "config": {
        "condition": "cache_check.hit == true"
      }
    },
    {
      "id": "run_ingest",
      "type": "AGENT",
      "label": "Structural Pass",
      "config": {
        "agent_name": "ingest-agent",
        "input_mapping": {
          "mode": { "type": "literal", "value": "structural" },
          "content": { "type": "expression", "value": "intake.material_content" },
          "subject_id": { "type": "expression", "value": "intake.subject_id" }
        }
      }
    },
    {
      "id": "write_cache",
      "type": "FUNCTION",
      "label": "Write Cache",
      "config": {
        "function_name": "cache-write",
        "input_mapping": {
          "cache_key": { "type": "expression", "value": "intake.material_hash" },
          "cache_type": { "type": "literal", "value": "structural" },
          "output_path": { "type": "expression", "value": "run_ingest.output_path" },
          "subject_id": { "type": "expression", "value": "intake.subject_id" }
        }
      }
    },
    {
      "id": "generate_plan",
      "type": "FUNCTION",
      "label": "Generate Plan",
      "config": {
        "function_name": "generate-plan",
        "input_mapping": {
          "subject_id": { "type": "expression", "value": "intake.subject_id" }
        }
      }
    },
    {
      "id": "end",
      "type": "END",
      "label": "Done"
    }
  ],
  "edges": [
    { "id": "e1", "source": "intake", "target": "cache_check" },
    { "id": "e2", "source": "cache_check", "target": "cache_hit_decision" },
    { "id": "e3", "source": "cache_hit_decision", "target": "run_ingest", "label": "miss" },
    { "id": "e4", "source": "cache_hit_decision", "target": "generate_plan", "label": "hit" },
    { "id": "e5", "source": "run_ingest", "target": "write_cache" },
    { "id": "e6", "source": "write_cache", "target": "generate_plan" },
    { "id": "e7", "source": "generate_plan", "target": "end" }
  ]
}
